generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "views"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis, uuid_ossp(map: "uuid-ossp")]
}

model User {
    id                     String                     @id(map: "PK_a3ffb1c0c8416b9fc6f907b7433") @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
    created_at             DateTime                   @default(now()) @db.Timestamp(6)
    updated_at             DateTime                   @default(now()) @db.Timestamp(6)
    username               String                     @db.VarChar
    email                  String                     @unique @db.VarChar
    password               String?                     @db.VarChar
    provider               String?                    @db.VarChar
    avatarUrl              String?                    @db.VarChar
    email_verified         DateTime?
    provider_id            String?                    @db.VarChar
    accounts               Account[]
    refresh_token          RefreshToken[]
    sessions               Session[]
    member_on              Member[]
    created_projects       Project[]                 @relation("projects_created")
    organizations_owned    Organization[]            @relation("organizations_owned")
    invites_sent           Invite[]                  @relation("invites_sent")
    verification_tokens    VerificationToken[]

  @@map("users")
}

enum UserRole {
  MEMBER
  ADMIN
  OWNER
  GUEST
  BILLING
}

model Invite {
    id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
    created_at DateTime @default(now()) @db.Timestamp(6)
    updated_at DateTime @default(now()) @db.Timestamp(6)
    role       UserRole @default(MEMBER)
    email      String   @db.VarChar
    token      String   @db.VarChar
    expires_at DateTime @db.Timestamp(6)
    used       Boolean  @default(false)
    user_id  String?   @db.Uuid
    organization_id String @db.Uuid
    author     User?     @relation("invites_sent", fields: [user_id], references: [id], onDelete: Cascade)
    organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

    @@map("invites")
}

model Member {
    id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
    created_at  DateTime @default(now()) @db.Timestamp(6)
    updated_at  DateTime @default(now()) @db.Timestamp(6)
    user_id     String   @db.Uuid
    organization_id String @db.Uuid
    user        User     @relation(fields: [user_id], references: [id], onDelete: Cascade)
    organization Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
    members_permissions MemberPermission[]
    members_roles     MemberRole[]
    @@unique([user_id, organization_id])
    @@map("members")
}

model Organization {
    id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
    created_at DateTime @default(now()) @db.Timestamp(6) @map("created_at")
    updated_at DateTime @default(now()) @db.Timestamp(6) @map("updated_at")
    name       String   @db.VarChar
    slug       String   @unique @db.VarChar
    domain    String? @unique @db.VarChar
    shouldAttachDomain Boolean @default(false) @map("should_attach_domain")
    avatarUrl  String?  @db.VarChar
    members    Member[]
    projects   Project[]
    owner_id   String   @db.Uuid
    owner      User     @relation("organizations_owned", fields: [owner_id], references: [id], onDelete: Cascade)
    invites    Invite[]

    @@map("organizations")
}

model Project {
    id              String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
    created_at      DateTime @default(now()) @db.Timestamp(6)
    updated_at      DateTime @default(now()) @db.Timestamp(6)
    name            String   @db.VarChar
    description     String   @db.VarChar
    slug            String   @unique @db.VarChar
    avatarUrl       String?  @db.VarChar
    organization_id String   @db.Uuid
    organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
    owner_id        String   @db.Uuid
    owner           User     @relation("projects_created", fields: [owner_id], references: [id], onDelete: Cascade)
    @@map("projects")
}

model Role {
  id                  String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  created_at          DateTime         @default(now()) @db.Timestamp(6)
  updated_at          DateTime         @default(now()) @db.Timestamp(6)
  name                String           @db.VarChar
  description         String?           @db.VarChar
  permissions_roles   PermissionRole[]
  members_roles       MemberRole[]

  @@map("roles")
}

model Permission {
  id                String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  created_at        DateTime         @default(now()) @db.Timestamp(6)
  updated_at        DateTime         @default(now()) @db.Timestamp(6)
  name              String           @db.VarChar
  description       String           @db.VarChar
  permissions_roles PermissionRole[]
  users_permissions MemberPermission[]

  @@map("permissions")
}

model PermissionRole {
  role_id       String     @db.Uuid
  permission_id String     @db.Uuid
  permissions   Permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)
  roles         Role       @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@id([role_id, permission_id])
  @@index([permission_id])
  @@index([role_id])
  @@map("permissions_roles")
}

model RefreshToken {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @default(now()) @db.Timestamp(6)
  expires_in Int
  token      String   @db.VarChar
  user_id    String?  @db.Uuid
  users      User?    @relation(fields: [user_id], references: [id])

  @@map("refresh_token")
}

model MemberPermission {
  member_id       String     @db.Uuid
  permission_id String     @db.Uuid
  permissions   Permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)
  members       Member       @relation(fields: [member_id], references: [id], onDelete: Cascade)

  @@id([member_id, permission_id])
  @@index([member_id])
  @@index([permission_id])
  @@map("members_permissions")
}

model MemberRole {
  member_id String @db.Uuid
  role_id String @db.Uuid
  roles   Role   @relation(fields: [role_id], references: [id], onDelete: Cascade)
  member  Member   @relation(fields: [member_id], references: [id], onDelete: Cascade)

  @@id([member_id, role_id])
  @@index([role_id])
  @@index([member_id])
  @@map("members_roles")
}

enum TokenType {
  PASSWORD_RECOVERY
}

model VerificationToken {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  token      String   @unique
  type       TokenType @default(PASSWORD_RECOVERY)
  createdAt  DateTime @default(now()) @db.Timestamp(6)
  user_id    String   @db.Uuid
  user       User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  expires    DateTime

  @@unique([id, token])
  @@map("verification_tokens")
}

model Account {
  id                String  @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id           String  @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  sessionToken String   @unique
  user_id      String   @db.Uuid
  expires      DateTime
  user         User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("sessions")
}