  ativo            Boolean  @default(true)

  pessoa     Pessoa   @relation(fields: [pessoa_id], references: [id], onDelete: Cascade)
  empresa    Empresa  @relation(fields: [empresa_id], references: [id])
  organization     Organization @relation(fields: [organization_id], references: [id])
  cargo_funcionario CargoFuncionario? @relation(fields: [cargo_id], references: [id], onDelete: SetNull)
  profissionais Profissional[]
  funcionarios     ExameOcupacional[]
  folhas_pagamento_itens FolhaPagamentoItem[]
  @@map("funcionario")
  @@schema("common")

  @@index([organization_id])
  @@index([ativo])
  @@index([cargo_id])
  @@unique([organization_id, matricula])
  @@unique([empresa_id, pessoa_id])
}

model CargoFuncionario {
  id              String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organization_id String   @db.Uuid
  created_at      DateTime @default(now()) @db.Timestamp(6)
  updated_at      DateTime @updatedAt @db.Timestamp(6)
  codigo          String?  @db.VarChar(50)
  nome            String   @db.VarChar(120)
  descricao       String?
  salario_base    Decimal  @default(0) @db.Decimal(15, 2)
  ativo           Boolean  @default(true)

  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  funcionarios    Funcionario[]

  @@unique([organization_id, nome])
  @@unique([organization_id, codigo])
  @@index([organization_id, ativo])
  @@map("cargo_funcionario")
  @@schema("common")
}

model Profissional {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  funcionario_id     String     @db.Uuid
  registro    String
  tipo        String   // médico, engenheiro, técnico, etc.
  conselho    String   // CRM, CREA, etc.
  funcionario        Funcionario    @relation(fields: [funcionario_id], references: [id])
  ativo       Boolean  @default(true)

  @@map("profissional")
  @@schema("seguranca")
}

model LTCAT {
  id             String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  empresa_id     String     @db.Uuid
  ambiente_id    String     @db.Uuid
  profissional   String     // Nome do engenheiro/médico responsável
  registro_prof  String     // CREA, CRM, etc.
  numero_laudo   String     // Código interno do laudo
  data_emissao   DateTime
  data_validade  DateTime?
  observacoes    String?

  empresa        Empresa    @relation(fields: [empresa_id], references: [id])
  ambiente       Ambiente   @relation(fields: [ambiente_id], references: [id])
  riscos         LTCATRisco[]

  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@map("ltcat")
  @@schema("seguranca")
}

model LTCATRisco {
  id        String             @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  ltcat_id  String             @db.Uuid
  risco_id  String             @db.Uuid

  ltcat     LTCAT              @relation(fields: [ltcat_id], references: [id])
  risco     RiscoOcupacional   @relation(fields: [risco_id], references: [id])

  @@map("ltcat_risco")
  @@schema("seguranca")
}

// ==================== FROTA (operacional + vínculo financeiro) ====================

model Veiculo {
  id              String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organization_id String   @db.Uuid
  placa           String   @db.VarChar(10)
  modelo          String   @db.VarChar(255)
  marca           String   @db.VarChar(255)
  ano             Int?
  tipo            String?  @db.VarChar(50)
  km_atual        Float?
  ativo           Boolean  @default(true)
  created_at      DateTime @default(now()) @db.Timestamp(6)
  updated_at      DateTime @updatedAt @db.Timestamp(6)

  organization   Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  abastecimentos Abastecimento[]
  manutencoes    Manutencao[]
  viagens        Viagem[]
  lancamentos    Lancamento[] @relation("VeiculoLancamento")

  @@unique([organization_id, placa])
  @@index([organization_id])
  @@index([ativo])
  @@map("veiculos")
  @@schema("frota")
}

model Abastecimento {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  veiculo_id    String    @db.Uuid
  data          DateTime  @db.Timestamp(6)
  litros        Float
  valor         Decimal   @db.Decimal(15, 2)
  km            Float?
  lancamento_id String?   @unique @db.Uuid

  veiculo     Veiculo     @relation(fields: [veiculo_id], references: [id], onDelete: Cascade)
  lancamento  Lancamento? @relation(fields: [lancamento_id], references: [id], onDelete: Cascade)

  @@index([veiculo_id])
  @@index([data])
  @@map("abastecimentos")
  @@schema("frota")
}

model Manutencao {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  veiculo_id    String    @db.Uuid
  tipo          String    @db.VarChar(100)
  descricao     String?
  data          DateTime  @db.Timestamp(6)
  valor         Decimal   @db.Decimal(15, 2)
  lancamento_id String?   @unique @db.Uuid

  veiculo     Veiculo     @relation(fields: [veiculo_id], references: [id], onDelete: Cascade)
  lancamento  Lancamento? @relation(fields: [lancamento_id], references: [id], onDelete: Cascade)

  @@index([veiculo_id])
  @@index([data])
  @@map("manutencoes")
  @@schema("frota")
}

model Viagem {
  id            String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  veiculo_id    String    @db.Uuid
  origem        String    @db.VarChar(500)
  destino       String    @db.VarChar(500)
  data_inicio   DateTime  @db.Timestamp(6)
  data_fim      DateTime? @db.Timestamp(6)
  km_rodado     Float?
  valor         Decimal?  @db.Decimal(15, 2)
  lancamento_id String?   @unique @db.Uuid

  veiculo     Veiculo     @relation(fields: [veiculo_id], references: [id], onDelete: Cascade)
  lancamento  Lancamento? @relation(fields: [lancamento_id], references: [id], onDelete: Cascade)

  @@index([veiculo_id])
  @@index([data_inicio])
  @@map("viagens")
  @@schema("frota")
}

