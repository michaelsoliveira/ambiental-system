generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "views"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [postgis, uuid_ossp(map: "uuid-ossp")]
  schemas    = ["common", "monitoramento", "seguranca", "financeiro", "frota"]
}

model User {
  id                  String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  created_at          DateTime            @default(now()) @db.Timestamp(6)
  updated_at          DateTime            @updatedAt @db.Timestamp(6)
  username            String              @db.VarChar
  email               String              @unique @db.VarChar
  password            String?             @db.VarChar
  provider            String?             @db.VarChar
  avatarUrl           String?             @db.VarChar
  email_verified      DateTime?
  provider_id         String?             @db.VarChar
  
  accounts            Account[]
  refresh_token       RefreshToken[]
  pessoas_created            Pessoa[]      @relation("created_by")
  pessoas_owner             Pessoa[]      @relation("owner")
  sessions            Session[]
  member_on           Member[]
  organizations_owned Organization[]      @relation("organizations_owned")
  invites_sent        Invite[]            @relation("invites_sent")
  verification_tokens VerificationToken[]
  licencas            LicencaCondicionante[]
  notificacoes        NotificacaoCondicionante[]
  auditorias_notificacao AuditoriaNotificacao[]
  auditorias_licenca      AuditoriaLicenca[]
  fiscalizacoes           Fiscalizacao[]
  @@map("users")
  @@schema("common")
}

enum UserRole {
  MEMBER
  ADMIN
  OWNER
  GUEST
  BILLING
  @@schema("common")
}

model Invite {
  id              String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  created_at      DateTime     @default(now()) @db.Timestamp(6)
  updated_at      DateTime     @updatedAt @db.Timestamp(6)
  role            UserRole     @default(MEMBER)
  email           String       @db.VarChar
  token           String       @unique @db.VarChar
  expires_at      DateTime     @db.Timestamp(6)
  used            Boolean      @default(false)
  user_id         String?      @db.Uuid
  organization_id String       @db.Uuid
  
  author          User?        @relation("invites_sent", fields: [user_id], references: [id], onDelete: Cascade)
  organization    Organization @relation(fields: [organization_id], references: [id], onDelete: Cascade)

  @@map("invites")
  @@schema("common")
}

model Member {
  id              String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  created_at      DateTime            @default(now()) @db.Timestamp(6)
  updated_at      DateTime            @updatedAt @db.Timestamp(6)
  user_id         String              @db.Uuid
  organization_id String              @db.Uuid
  
  user            User                @relation(fields: [user_id], references: [id], onDelete: Cascade)
  organization    Organization        @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  members_permissions MemberPermission[]
  members_roles   MemberRole[]
  
  @@unique([user_id, organization_id])
  @@map("members")
  @@schema("common")
}

model Organization {
  id                  String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  created_at          DateTime            @default(now()) @db.Timestamp(6)
  updated_at          DateTime            @updatedAt @db.Timestamp(6)
  name                String              @db.VarChar
  slug                String              @unique @db.VarChar
  domain              String?             @unique @db.VarChar
  shouldAttachDomain  Boolean             @default(false)
  avatarUrl           String?             @db.VarChar
  owner_id            String              @db.Uuid
  
  owner               User                @relation("organizations_owned", fields: [owner_id], references: [id], onDelete: Cascade)
  members             Member[]
  invites             Invite[]  
  
  // Dados financeiros multi-organization
  parceiros             Parceiro[]
  contasBancarias       ContaBancaria[]
  centrosCusto          CentroCusto[]
  categoriasFinanceiras CategoriaFinanceira[]
  lancamentos           Lancamento[]
  lancamentosRecorrentes LancamentoRecorrente[]
  parcelas              Parcela[]
  documentos            DocumentoFinanceiro[]
  extratos              Extrato[]
  planoConta            PlanoConta[]
  configuracoes         ConfiguracaoFinanceira[]
  relatorios            Relatorio[]
  empresas              Empresa[]
  funcionarios          Funcionario[]
  cargosFuncionario     CargoFuncionario[]
  folhasPagamento       FolhaPagamento[]
  folhaPagamentoItens   FolhaPagamentoItem[]
  pessoas               Pessoa[]
  veiculos              Veiculo[]
  @@map("organizations")
  @@schema("common")
}
model Role {
  id                String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  created_at        DateTime         @default(now()) @db.Timestamp(6)
  updated_at        DateTime         @updatedAt @db.Timestamp(6)
  name              String           @db.VarChar
  description       String?          @db.VarChar
  permissions_roles PermissionRole[]
  members_roles     MemberRole[]

  @@map("roles")
  @@schema("common")
}

model Permission {
  id                String           @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  created_at        DateTime         @default(now()) @db.Timestamp(6)
  updated_at        DateTime         @updatedAt @db.Timestamp(6)
  name              String           @db.VarChar
  description       String           @db.VarChar
  permissions_roles PermissionRole[]
  users_permissions MemberPermission[]

  @@map("permissions")
  @@schema("common")
}

model PermissionRole {
  role_id       String     @db.Uuid
  permission_id String     @db.Uuid
  
  permissions   Permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)
  roles         Role       @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@id([role_id, permission_id])
  @@index([permission_id])
  @@index([role_id])
  @@map("permissions_roles")
  @@schema("common")
}

model RefreshToken {
  id         String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  created_at DateTime @default(now()) @db.Timestamp(6)
  updated_at DateTime @updatedAt @db.Timestamp(6)
  expires_in Int
  token      String   @db.VarChar
  user_id    String?  @db.Uuid
  
  users      User?    @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("refresh_token")
  @@schema("common")
}

model MemberPermission {
  member_id     String     @db.Uuid
  permission_id String     @db.Uuid
  
  permissions   Permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)
  members       Member     @relation(fields: [member_id], references: [id], onDelete: Cascade)

  @@id([member_id, permission_id])
  @@index([member_id])
  @@index([permission_id])
  @@map("members_permissions")
  @@schema("common")
}

model MemberRole {
  member_id String @db.Uuid
  role_id   String @db.Uuid
  
  roles     Role   @relation(fields: [role_id], references: [id], onDelete: Cascade)
  member    Member @relation(fields: [member_id], references: [id], onDelete: Cascade)

  @@id([member_id, role_id])
  @@index([role_id])
  @@index([member_id])
  @@map("members_roles")
  @@schema("common")
}

enum TokenType {
  PASSWORD_RECOVERY
  EMAIL_VERIFICATION
  @@schema("common")
}

model VerificationToken {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  token     String   @unique
  type      TokenType @default(PASSWORD_RECOVERY)
  createdAt DateTime @default(now()) @db.Timestamp(6)
  expires   DateTime
  user_id   String   @db.Uuid
  
  user      User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([id, token])
  @@map("verification_tokens")
  @@schema("common")
}

model Account {
  id                String @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  user_id           String @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  
  user              User   @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
  @@schema("common")
}

model Session {
  id           String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  sessionToken String   @unique
  user_id      String   @db.Uuid
  expires      DateTime
  
  user         User     @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("sessions")
  @@schema("common")
}

// ==================== SCHEMA FINANCEIRO MULTI-organization ====================
model Parceiro {
  id                  String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organization_id     String              @db.Uuid
  created_at          DateTime            @default(now()) @db.Timestamp(6)
  updated_at          DateTime            @updatedAt @db.Timestamp(6)
  
  // codigo              String              @db.VarChar(100)
  tipo_parceiro       TipoParceiro
  pessoa_id           String              @db.Uuid
  observacoes         String?
  ativo               Boolean             @default(true)
  
  pessoa              Pessoa              @relation(fields: [pessoa_id], references: [id], onDelete: Cascade)
  organization        Organization        @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  lancamentos         Lancamento[]
  lancamentosRecorrentes LancamentoRecorrente[]
  documentos          DocumentoFinanceiro[]
  
  @@unique([organization_id, pessoa_id])
  @@index([organization_id])
  @@index([ativo])
  @@map("parceiros")
  @@schema("financeiro")
}

// PC_Banco - Contas Bancárias e Contábeis
model ContaBancaria {
  id                  String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organization_id     String              @db.Uuid
  created_at          DateTime            @default(now()) @db.Timestamp(6)
  updated_at          DateTime            @updatedAt @db.Timestamp(6)
  
  codigo              String              @db.VarChar(100)
  nome                String              @db.VarChar(255)
  tipo_conta          TipoConta           @default(BANCARIA)
  
  // Campos para contas bancárias (opcionais, apenas para tipo BANCARIA)
  banco               String?             @db.VarChar(100)
  agencia             String?
  numero              String?
  digito              String?
  tipoConta           TipoContaBancaria?
  saldoInicial        Decimal             @default(0) @db.Decimal(15, 2)
  saldoAtual          Decimal             @default(0) @db.Decimal(15, 2)
  limiteCredito       Decimal?            @db.Decimal(15, 2)
  dataAbertura        DateTime?
  
  // Campos para contas contábeis (plano de contas)
  conta_pai_id        String?             @db.Uuid
  
  ativo               Boolean             @default(true)
  observacoes         String?
  
  organization        Organization        @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  conta_pai           ContaBancaria?      @relation("ContaHierarchy", fields: [conta_pai_id], references: [id], onDelete: SetNull)
  subcontas           ContaBancaria[]     @relation("ContaHierarchy")
  lancamentos         Lancamento[]
  lancamentosRecorrentes LancamentoRecorrente[]
  extratos            Extrato[]
  
  @@unique([organization_id, codigo])
  @@index([organization_id])
  @@index([ativo])
  @@index([tipo_conta])
  @@index([conta_pai_id])
  @@map("contas_bancarias")
  @@schema("financeiro")
}

// PC_CC - Centros de Custo
model CentroCusto {
  id                  String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organization_id     String              @db.Uuid
  created_at          DateTime            @default(now()) @db.Timestamp(6)
  updated_at          DateTime            @updatedAt @db.Timestamp(6)
  
  codigo              String              @db.VarChar(100)
  nome                String              @db.VarChar(255)
  descricao           String?
  responsavel         String?
  email               String?
  ativo               Boolean             @default(true)
  
  organization        Organization        @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  lancamentos         Lancamento[]
  lancamentosRecorrentes LancamentoRecorrente[]
  
  @@unique([organization_id, codigo])
  @@index([organization_id])
  @@index([ativo])
  @@map("centros_custo")
  @@schema("financeiro")
}

// PC_Rec e PC_Des - Categorias Financeiras
model CategoriaFinanceira {
  id                  String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organization_id     String              @db.Uuid
  created_at          DateTime            @default(now()) @db.Timestamp(6)
  updated_at          DateTime            @updatedAt @db.Timestamp(6)
  
  codigo              String              @db.VarChar(100)
  nome                String              @db.VarChar(255)
  descricao           String?
  tipo                TipoCategoria
  nivel               Int                 @default(1)
  parent_id            String?             @db.Uuid
  ativo               Boolean             @default(true)
  
  organization        Organization        @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  parent              CategoriaFinanceira? @relation("SubcategoriasDe", fields: [parent_id], references: [id], onDelete: SetNull)
  subcategorias       CategoriaFinanceira[] @relation("SubcategoriasDe")
  lancamentos         Lancamento[]
  lancamentosRecorrentes LancamentoRecorrente[]
  
  @@unique([organization_id, codigo])
  @@index([organization_id])
  @@index([tipo])
  @@index([ativo])
  @@index([parent_id])
  @@map("categoria_financeira")
  @@schema("financeiro")
}

// Plano de Contas
model PlanoConta {
  id                  String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organization_id     String              @db.Uuid
  created_at          DateTime            @default(now()) @db.Timestamp(6)
  updated_at          DateTime            @updatedAt @db.Timestamp(6)
  
  codigo              String              @db.VarChar(50)
  nome                String              @db.VarChar(255)
  tipo                TipoContaPlano      // ATIVA, PASSIVA, RECEITA, DESPESA
  nivel               Int
  parent_id            String?             @db.Uuid
  descricao           String?
  ativo               Boolean             @default(true)
  
  organization        Organization        @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  parent              PlanoConta?        @relation("PlanoContaHierarchy", fields: [parent_id], references: [id], onDelete: SetNull)
  subcontas           PlanoConta[]       @relation("PlanoContaHierarchy")
  
  @@unique([organization_id, codigo])
  @@index([organization_id])
  @@index([tipo])
  @@map("plano_contas")
  @@schema("financeiro")
}

// PC_Transf - Lançamentos
model Lancamento {
  id                      String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organization_id         String              @db.Uuid
  created_at              DateTime            @default(now()) @db.Timestamp(6)
  updated_at              DateTime            @updatedAt @db.Timestamp(6)
  
  numero                  String              @db.VarChar(100)
  tipo                    TipoLancamento
  data                    DateTime
  data_vencimento          DateTime?
  data_competencia         String?             @db.VarChar(7) // MM/YYYY
  descricao               String              @db.VarChar(500)
  observacoes             String?
  valor                   Decimal             @db.Decimal(15, 2)
  valor_pago               Decimal?            @db.Decimal(15, 2)
  pago                    Boolean             @default(false)
  data_pagamento           DateTime?
  forma_parcelamento       FormaParcelamento   @default(UNICA)
  numero_parcelas          Int                 @default(1)
  status_lancamento        StatusLancamento    @default(PENDENTE)
  
  // Repetição
  tipo_repeticao          TipoRepeticao       @default(NENHUMA)
  parcela_atual           Int?                // Para parcelados (1, 2, 3...)
  lancamento_origem_id    String?             @db.Uuid // Para parcelas
  
  // Controle interno e integração Asaas
  controle_interno        Boolean             @default(false) // Se true, apenas registro interno sem cobrança no Asaas
  gerar_boleto            Boolean             @default(false)
  permitir_pix            Boolean             @default(false)
  asaas_payment_id        String?             @db.VarChar(255) // ID da cobrança no Asaas
  invoice_url            String?             @db.VarChar(500) // URL da invoice/cobrança no Asaas
  boleto_url              String?             @db.VarChar(500)
  boleto_linha_digitavel  String?             @db.VarChar(100)
  pix_qrcode_url          String?             @db.VarChar(500)
  
  // Recorrente
  periodicidade           Periodicidade?
  data_fim_repeticao      DateTime?
  lancamento_recorrente_id String?             @db.Uuid
  
  categoria_id             String              @db.Uuid
  conta_bancaria_id         String              @db.Uuid
  centro_custo_id           String?             @db.Uuid
  parceiro_id              String?             @db.Uuid
  lancamento_transferencia_id String?           @db.Uuid
  /// Vínculo opcional com veículo (frota) — valor contábil continua só no lançamento.
  veiculo_id               String?             @db.Uuid
  
  organization            Organization        @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  categoria               CategoriaFinanceira @relation(fields: [categoria_id], references: [id])
  conta_bancaria           ContaBancaria       @relation(fields: [conta_bancaria_id], references: [id])
  centro_custo             CentroCusto?        @relation(fields: [centro_custo_id], references: [id])
  parceiro                Parceiro?           @relation(fields: [parceiro_id], references: [id])
  lancamento_transferencia Lancamento?         @relation("TransferenciaEntre", fields: [lancamento_transferencia_id], references: [id], onDelete: SetNull)
  lacamentos_relacionados Lancamento[]        @relation("TransferenciaEntre")
  lancamento_origem       Lancamento?         @relation("LancamentoParcelas", fields: [lancamento_origem_id], references: [id], onDelete: SetNull)
  parcelas_origem         Lancamento[]        @relation("LancamentoParcelas")
  lancamento_recorrente    LancamentoRecorrente? @relation(fields: [lancamento_recorrente_id], references: [id], onDelete: SetNull)
  veiculo                  Veiculo?            @relation("VeiculoLancamento", fields: [veiculo_id], references: [id], onDelete: SetNull)
  abastecimento            Abastecimento?
  manutencao               Manutencao?
  viagem                   Viagem?
  
  parcelas                Parcela[]
  documentos              DocumentoFinanceiro[]
  
  @@unique([organization_id, numero])
  @@index([organization_id])
  @@index([tipo])
  @@index([pago])
  @@index([status_lancamento])
  @@index([data])
  @@index([categoria_id])
  @@index([conta_bancaria_id])
  @@index([tipo_repeticao])
  @@index([lancamento_origem_id])
  @@index([lancamento_recorrente_id])
  @@index([veiculo_id])
  @@map("lancamentos")
  @@schema("financeiro")
}

// Lançamentos Recorrentes
model LancamentoRecorrente {
  id                      String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organization_id         String              @db.Uuid
  created_at              DateTime            @default(now()) @db.Timestamp(6)
  updated_at              DateTime            @updatedAt @db.Timestamp(6)
  
  tipo                    TipoLancamento
  descricao               String              @db.VarChar(500)
  valor                   Decimal             @db.Decimal(15, 2)
  periodicidade           Periodicidade
  data_inicio             DateTime
  data_fim                DateTime?           // None = sem data de fim
  dia_vencimento          Int?                // Dia do mês (1-31)
  
  categoria_id             String              @db.Uuid
  conta_bancaria_id         String              @db.Uuid
  centro_custo_id           String?             @db.Uuid
  parceiro_id              String?             @db.Uuid
  
  ativo                   Boolean             @default(true)
  gerar_boleto            Boolean             @default(false)
  permitir_pix            Boolean             @default(false)
  asaas_subscription_id   String?             @db.VarChar(255) // ID da assinatura no Asaas
  
  organization            Organization        @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  categoria               CategoriaFinanceira @relation(fields: [categoria_id], references: [id])
  conta_bancaria           ContaBancaria       @relation(fields: [conta_bancaria_id], references: [id])
  centro_custo             CentroCusto?        @relation(fields: [centro_custo_id], references: [id])
  parceiro                Parceiro?           @relation(fields: [parceiro_id], references: [id])
  lancamentos             Lancamento[]
  
  @@index([organization_id])
  @@index([ativo])
  @@index([data_inicio])
  @@map("lancamentos_recorrentes")
  @@schema("financeiro")
}

// Parcelas de Lançamentos
model Parcela {
  id                  String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  lancamento_id        String              @db.Uuid
  organization_id        String              @db.Uuid
  created_at          DateTime            @default(now()) @db.Timestamp(6)
  updated_at          DateTime            @updatedAt @db.Timestamp(6)
  
  numero_parcela       Int
  data_vencimento      DateTime
  valor               Decimal             @db.Decimal(15, 2)
  valorPago           Decimal?            @db.Decimal(15, 2)
  pago                Boolean             @default(false)
  data_pagamento       DateTime?
  status_parcela       StatusParcela       @default(PENDENTE)
  observacoes         String?
  
  lancamento          Lancamento          @relation(fields: [lancamento_id], references: [id], onDelete: Cascade)
  organization        Organization        @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  @@unique([lancamento_id, numero_parcela])
  @@index([data_vencimento])
  @@index([status_parcela])
  @@map("parcelas")
  @@schema("financeiro")
}

// Documentos (NFe, Recibos, etc)
model DocumentoFinanceiro {
  id                  String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  lancamento_id        String              @db.Uuid
  organization_id        String              @db.Uuid
  parceiro_id          String?             @db.Uuid
  created_at          DateTime            @default(now()) @db.Timestamp(6)
  updated_at          DateTime            @updatedAt @db.Timestamp(6)
  
  tipo                TipoDocumento
  numero              String              @db.VarChar(100)
  serie               String?             @db.VarChar(50)
  data_documento       DateTime
  url                 String?
  path      String?
  observacoes         String?
  
  lancamento          Lancamento          @relation(fields: [lancamento_id], references: [id], onDelete: Cascade)
  parceiro            Parceiro?           @relation(fields: [parceiro_id], references: [id], onDelete: SetNull)
  organization        Organization        @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  @@unique([tipo, numero, serie])
  @@index([lancamento_id])
  @@index([parceiro_id])
  @@map("documentos_financeiro")
  @@schema("financeiro")
}

// Extratos Bancários
model Extrato {
  id                  String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organization_id        String              @db.Uuid
  conta_bancaria_id     String              @db.Uuid
  created_at          DateTime            @default(now()) @db.Timestamp(6)
  
  dataExtrato         DateTime
  saldoInicial        Decimal             @db.Decimal(15, 2)
  saldoFinal          Decimal             @db.Decimal(15, 2)
  totalEntradas       Decimal             @db.Decimal(15, 2)
  totalSaidas         Decimal             @db.Decimal(15, 2)
  
  conta_bancaria       ContaBancaria       @relation(fields: [conta_bancaria_id], references: [id], onDelete: Cascade)
  organization        Organization        @relation(fields: [organization_id], references: [id], onDelete: Cascade)
  @@index([conta_bancaria_id])
  @@index([dataExtrato])
  @@map("extratos")
  @@schema("financeiro")
}

// Configurações Financeiras por Organização
model ConfiguracaoFinanceira {
  id                  String              @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  organization_id     String              @unique @db.Uuid
  created_at          DateTime            @default(now()) @db.Timestamp(6)
  updated_at          DateTime            @updatedAt @db.Timestamp(6)
  
  moedaPadrao         String              @default("BRL")
  casasDecimais       Int                 @default(2)
  diasCarencia        Int                 @default(0)
  gerarDreAutomatico  Boolean             @default(false)
