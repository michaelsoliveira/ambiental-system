{
    "name": "@saas/api",
    "version": "0.0.0",
    "main": "src/index.ts",
    "types": "src/index.ts",
    "devDependencies": {
        "@faker-js/faker": "^10.1.0",
        "@saas/env": "workspace:*",
        "@saas/eslint": "workspace:*",
        "@saas/prettier": "workspace:*",
        "@saas/tsconfig": "workspace:*",
        "@types/bcrypt": "^6.0.0",
        "prisma": "6.16.1",
        "tsx": "^4.20.6"
    },
    "eslintConfig": {
        "extends": [
            "@saas/eslint/next-js"
        ]
    },
    "prisma": {
        "seed": "npx tsx prisma/seeds.ts"
    },
    "prettier": "@saas/prettier",
    "scripts": {
        "dev": "pnpm env:load tsx watch src/http/server.ts",
        "db:seed": "pnpm env:load prisma db seed",
        "db:seed:prod": "prisma db seed",
        "db:migrate": "pnpm env:load prisma migrate dev",
        "db:studio": "pnpm env:load prisma studio",
        "env:load": "dotenv -e ../../.env --",
        "build": "tsup",
        "start": "node dist/server.js",
        "convert:csv": "tsx src/scripts/convert-csv-to-sql.ts src/scripts/data/municipios.csv src/scripts/data/municipios.sql"
    },
    "dependencies": {
        "@fastify/cors": "^11.1.0",
        "@fastify/jwt": "^10.0.0",
        "@fastify/multipart": "^9.2.1",
        "@fastify/swagger": "^9.5.2",
        "@fastify/swagger-ui": "^5.2.3",
      "@prisma/adapter-pg": "6.16.1",
        "@prisma/client": "6.16.1",
        "@saas/auth": "workspace:*",
        "bcrypt": "^6.0.0",
        "dotenv": "^17.2.3",
        "dotenv-cli": "^10.0.0",
        "fastify": "^5.6.1",
        "fastify-plugin": "^5.1.0",
        "fastify-type-provider-zod": "^6.0.0",
        "jsonwebtoken": "^9.0.2",
      "pg": "^8.12.0",
        "tsup": "^8.5.0",
        "vitest": "^3.2.4",
        "zod": "^4.1.12"
    }
}