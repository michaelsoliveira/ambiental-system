{
  "name": "ambiental-system",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "docker:prod": "docker compose -f docker-compose.prod.yml --env-file .env up -d --build",
    "docker:prod:gateway": "docker compose -f docker-compose.prod.yml -f docker-compose.gateway.yml --env-file .env up -d --build",
    "docker:prod:logs": "docker compose -f docker-compose.prod.yml -f docker-compose.gateway.yml logs -f",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types"
  },
  "devDependencies": {
    "turbo": "^2.5.6"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
