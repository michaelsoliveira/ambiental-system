# API Fastify + Prisma — build a partir da raiz do monorepo
# docker build -f docker/Dockerfile.api -t ambiental-api .

FROM node:22-alpine AS base
RUN apk add --no-cache libc6-compat openssl && \
    corepack enable && corepack prepare pnpm@9.0.0 --activate
WORKDIR /app

FROM base AS builder
COPY package.json pnpm-lock.yaml pnpm-workspace.yaml turbo.json ./
COPY apps ./apps
COPY packages ./packages
COPY config ./config

RUN pnpm install --frozen-lockfile

# Prisma CLI está em apps/api (devDependency); `pnpm exec` na raiz não encontra o binário.
ENV DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/postgres"
WORKDIR /app/apps/api
RUN pnpm exec prisma generate
WORKDIR /app

ENV NODE_ENV=production
RUN pnpm turbo run build --filter=@saas/api

FROM base AS runner
RUN apk add --no-cache libc6-compat openssl && \
    addgroup -g 1001 -S nodejs && adduser -S nodejs -u 1001 -G nodejs && \
    npm install -g prisma@6.16.1

WORKDIR /app

COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/apps/api/dist ./apps/api/dist
COPY --from=builder /app/apps/api/prisma ./apps/api/prisma
COPY --from=builder /app/apps/api/package.json ./apps/api/package.json
COPY docker/entrypoint-api.sh /entrypoint-api.sh
RUN chmod +x /entrypoint-api.sh && chown -R nodejs:nodejs /app

USER nodejs
EXPOSE 3333

ENV NODE_ENV=production
ENTRYPOINT ["/entrypoint-api.sh"]
