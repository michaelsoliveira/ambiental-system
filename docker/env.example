# Copie para a raiz do repositório: cp docker/env.example .env

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=altere_esta_senha
POSTGRES_DB=ambiental

# --- API (Fastify) — obrigatórios (@saas/env) ---
JWT_SECRET=gerar_string_longa_aleatoria
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# Deve coincidir com a URL pública da API (domínio ou IP:porta exposta no host)
GITHUB_OAUTH_CLIENT_REDIRECT_URI=http://localhost:3334/auth/callback/github

# URL pública da API (browser + build do Next). Use o mesmo host/porta que o usuário acessa.
# Ex.: https://api-ambiental.seudominio.com (recomendado com proxy) ou http://SEU_IP:3334
NEXT_PUBLIC_API_URL=http://localhost:3334

# --- Portas no HOST (evite conflito com licencas: 3000 e 3333) ---
# Mapeamento: host:container — API continua em 3333 e o Next em 3000 *dentro* da rede Docker.
API_PORT=3334
FINANCEIRO_PORT=3001

# --- Opcional: Asaas ---
# ASAAS_API_KEY=
# ASAAS_ENV=sandbox
# ASAAS_WEBHOOK_TOKEN=

# Pular migrações na subida do container (0 = executa migrate deploy)
# SKIP_MIGRATE=0
