# Copie para a raiz: cp docker/env.example .env

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=altere_esta_senha
POSTGRES_DB=ambiental

# --- API (@saas/env) ---
JWT_SECRET=gerar_string_longa_aleatoria
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
# URL de callback registrada no GitHub OAuth App (geralmente o front ou a API, conforme o fluxo)
GITHUB_OAUTH_CLIENT_REDIRECT_URI=https://financeiro.bomanejo.com.br/api/auth/callback

# URL pública da API (HTTPS no domínio real)
# Os três GITHUB_* acima têm de existir também no processo do Next (financeiro): docker-compose.prod.yml repete-os no serviço financeiro.
NEXT_PUBLIC_API_URL=https://api-financeiro.bomanejo.com.br

# --- Opcional: Asaas ---
# ASAAS_API_KEY=
# ASAAS_ENV=sandbox
# ASAAS_WEBHOOK_TOKEN=

# SKIP_MIGRATE=0
