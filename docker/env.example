# Copie para a raiz do repositório: cp docker/env.example .env

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=altere_esta_senha
POSTGRES_DB=ambiental

# --- API (Fastify) — obrigatórios (@saas/env) ---
JWT_SECRET=gerar_string_longa_aleatoria
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
GITHUB_OAUTH_CLIENT_REDIRECT_URI=http://localhost:3333/auth/callback/github

# URL pública da API (usada no browser e na validação de env)
# Ex.: https://api.seudominio.com ou http://localhost:3333 em testes locais
NEXT_PUBLIC_API_URL=http://localhost:3333

# --- Portas publicadas no host ---
API_PORT=3333
FINANCEIRO_PORT=3000

# --- Opcional: Asaas ---
# ASAAS_API_KEY=
# ASAAS_ENV=sandbox
# ASAAS_WEBHOOK_TOKEN=

# Pular migrações na subida do container (0 = executa migrate deploy)
# SKIP_MIGRATE=0
